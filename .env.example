# ===========================================
# VAANI SETU - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git!

# ===========================================
# FRONTEND (VITE) - PUBLIC VARIABLES
# These are exposed to the browser (prefix with VITE_)
# ===========================================

# Supabase - These are public anon keys (safe to expose)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Base URL (leave empty for same-origin, or set for different domain)
# For local development: http://localhost:3000
# For production: leave empty (uses relative paths)
VITE_API_BASE_URL=

# OpenPose endpoint (optional)
VITE_OPENPOSE_ENDPOINT=

# ===========================================
# BACKEND (SERVER-SIDE) - SECRET VARIABLES
# These are NEVER exposed to the browser
# Set these in Vercel/Netlify dashboard
# ===========================================

# Gemini API Key (REQUIRED for AI chatbot)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Supabase Service Role Key (for admin operations)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
